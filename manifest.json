{
  "manifest_version": 3,
  "name": "SOLi",
  "version": "1.0.0",
  "description": "SOLi is a Solana Chrome extension for managing wallets, tokens, transactions, and key utilities.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon.png",
      "48":  "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["activeTab", "tabs", "storage"]
}